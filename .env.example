# ─── ElevenLabs (narration) ───────────────────────────────────────────────
# Get your key: elevenlabs.io → your profile → API Keys → Create.
ELEVENLABS_API_KEY=

# Model: eleven_multilingual_v2 handles FR/ES/IT/PT/DE well. Leave as-is unless
# you want to try eleven_turbo_v2_5 (faster/cheaper) or eleven_v3.
ELEVENLABS_MODEL=eleven_v3

# Voice used when a language has no specific voice below (Rachel, multilingual).
ELEVENLABS_VOICE=21m00Tcm4TlvDq8ikWAM

# English voice for the spoken English translations (keep an English/American voice).
ELEVENLABS_VOICE_EN=21m00Tcm4TlvDq8ikWAM

# Optional: a native-sounding voice per language. Copy the Voice ID from
# elevenlabs.io → Voices → (voice) → "ID". Recommended for quality.
ELEVENLABS_VOICE_FR=
ELEVENLABS_VOICE_ES=
ELEVENLABS_VOICE_IT=
ELEVENLABS_VOICE_PT=
ELEVENLABS_VOICE_DE=

# ─── Four voices for the script pipeline (v3 tags require eleven_v3 above) ───
ELEVENLABS_VOICE_FR_WOMAN=5OnMHwgTFgvPVwE8jP6B
ELEVENLABS_VOICE_FR_MAN=j9RedbMRSNQ74PyikQwD
ELEVENLABS_VOICE_EN_MAN=3TStB8f3X3To0Uj5R7RK
ELEVENLABS_VOICE_EN_WOMAN=ZqvIIuD5aI9JFejebHiH

# ─── Recraft (images) ─────────────────────────────────────────────────────
# API token from recraft.ai → profile → API (individual, pay-as-you-go).
RECRAFT_API_TOKEN=
# Base illustration style (digital_illustration | vector_illustration | ...).
RECRAFT_STYLE=digital_illustration
# Set once you create a custom style (npm run images:style). Optional: without
# it, images use the base style + style lock.
RECRAFT_STYLE_ID=

# ─── Anthropic Claude (transcript generator) ───
# Key from platform.claude.com → API keys.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
